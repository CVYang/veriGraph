{
  "module_name": "if_id_reg",
  "type": "pipeline_register",
  "description": "Pipeline register between IF and ID stages",
  "ports": [
    {
      "name": "clk",
      "direction": "input",
      "width": 1,
      "description": "Clock"
    },
    {
      "name": "rst_n",
      "direction": "input",
      "width": 1,
      "description": "Active-low reset"
    },
    {
      "name": "flush",
      "direction": "input",
      "width": 1,
      "description": "Flush signal (invalidates output)"
    },
    {
      "name": "stall",
      "direction": "input",
      "width": 1,
      "description": "Stall signal (holds current value)"
    },
    {
      "name": "if_pc",
      "direction": "input",
      "width": 32,
      "description": "PC from IF stage"
    },
    {
      "name": "if_instr",
      "direction": "input",
      "width": 32,
      "description": "Instruction from IF stage"
    },
    {
      "name": "if_valid",
      "direction": "input",
      "width": 1,
      "description": "Valid from IF stage"
    },
    {
      "name": "id_pc",
      "direction": "output",
      "width": 32,
      "description": "PC to ID stage"
    },
    {
      "name": "id_instr",
      "direction": "output",
      "width": 32,
      "description": "Instruction to ID stage"
    },
    {
      "name": "id_valid",
      "direction": "output",
      "width": 1,
      "description": "Valid to ID stage"
    }
  ],
  "functionality": "Captures IF stage outputs (PC, instruction, valid) on the rising edge of clk when stall is deasserted. On reset, outputs are cleared. On flush, the valid bit is cleared, effectively turning the instruction into a NOP. On stall, the register holds its current value, preserving the instruction for the next cycle.",
  "dependencies": []
}